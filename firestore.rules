rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───────────────────────────────────────────
    // ORDERS COLLECTION
    // ───────────────────────────────────────────
    match /orders/{orderId} {

      // Anyone signed in can CREATE an order, but only for themselves
      // (the uid field in the order must match their own auth uid)
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;

      // READ access:
      //   - the owner (pradakshinask@gmail.com) can read ANY order
      //   - a regular customer can only read orders where uid == their own uid
      allow read: if request.auth != null
                  && (
                       request.auth.token.email == 'pradakshinask@gmail.com'
                       || resource.data.uid == request.auth.uid
                     );

      // UPDATE (e.g. changing order status):
      //   - only the owner can update any order (used for status changes in admin panel)
      allow update: if request.auth != null
                    && request.auth.token.email == 'pradakshinask@gmail.com';

      // DELETE: only the owner, just in case
      allow delete: if request.auth != null
                    && request.auth.token.email == 'pradakshinask@gmail.com';
    }

    // ───────────────────────────────────────────
    // STATS COLLECTION (legacy/optional aggregate doc)
    // ───────────────────────────────────────────
    match /stats/{statId} {
      allow read: if request.auth != null
                  && request.auth.token.email == 'pradakshinask@gmail.com';
      allow write: if request.auth != null
                  && request.auth.token.email == 'pradakshinask@gmail.com';
    }

    // ───────────────────────────────────────────
    // Deny everything else by default
    // ───────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
